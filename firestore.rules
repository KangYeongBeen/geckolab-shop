rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // 상품 - 누구나 읽기 가능, 관리자만 쓰기
    match /products/{productId} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.token.email == 'admin@geckolab.kr';

      // 리뷰 - 누구나 읽기, 로그인한 사용자만 작성, 관리자만 삭제
      match /reviews/{reviewId} {
        allow read: if true;
        allow create: if request.auth != null;
        allow delete: if request.auth != null && request.auth.token.email == 'admin@geckolab.kr';
      }
    }

    // 공지사항 - 누구나 읽기, 관리자만 쓰기
    match /notices/{noticeId} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.token.email == 'admin@geckolab.kr';
    }

    // 회원 정보 - 본인만 읽기/쓰기, 관리자는 모두 접근
    match /users/{userId} {
      allow read, write: if request.auth != null &&
        (request.auth.uid == userId || request.auth.token.email == 'admin@geckolab.kr');
    }
  }
}